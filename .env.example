BOT_PORT=8080
TZ=Asia/Hong_Kong
LOG_LEVEL=INFO
SUPERUSERS=[]
MINGYI_VERSION=dev
MINGYI_IMAGE=ghcr.io/emberigor/mingyibot:latest

# Optional. Watchtower image update check interval in seconds.
WATCHTOWER_POLL_INTERVAL=60
WATCHTOWER_CLEANUP=true
WATCHTOWER_HTTP_API_TOKEN=change-me-random-token
WATCHTOWER_HTTP_API_URL=http://watchtower:8080/v1/update
WATCHTOWER_UPDATE_IMAGE=ghcr.io/emberigor/mingyibot:latest
WATCHTOWER_HTTP_TIMEOUT_SECONDS=10
# Optional. Only needed when Watchtower pulls a private image.
REPO_USER=
REPO_PASS=

# Optional. Keep this identical to the access token configured in NapCat/Lagrange.
ONEBOT_ACCESS_TOKEN=

# Optional. MySQL connection for database integration tests and future features.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=mingyibot
MYSQL_USER=mingyi
MYSQL_PASSWORD=
MYSQL_CONNECT_TIMEOUT_SECONDS=5

# Optional. Group message archive defaults. Archive stays off unless enabled here or by group command.
MESSAGE_ARCHIVE_ENABLED=false
MESSAGE_ARCHIVE_RETENTION_DAYS=90

# Optional. Shared OpenAI-compatible provider with Responses API support.
AI_KEY=
AI_BASEURL=
AI_MODEL=

# Optional. AI chat overrides. Empty values fall back to AI_KEY/AI_BASEURL/AI_MODEL.
AICHAT_KEY=
AICHAT_BASEURL=
AICHAT_MODEL=
# Plugin-level web search switch for ai_chat only.
AICHAT_WEB_SEARCH=false
AICHAT_DEFAULT_ROLE=default
AICHAT_HISTORY_LIMIT=12
AICHAT_ROLES_PATH=data/ai_chat_roles.json
AICHAT_SESSION_TTL_MINUTES=1440
AICHAT_MEMORY_ENABLED=true
AICHAT_MEMORY_BACKEND=mysql
AICHAT_MEMORY_PATH=data/ai_chat_memories.json
AICHAT_MEMORY_MAX_ITEMS=20
AICHAT_MEMORY_SUMMARY_INTERVAL=3

# Optional. Daily 60s news scheduler and group filter.
DAILYNEWS_ENABLED=true
DAILYNEWS_TIME=08:30

# If the source still returns yesterday's date at DAILYNEWS_TIME, retry until this time.
DAILYNEWS_LATEST_TIME=10:10
DAILYNEWS_RETRY_INTERVAL_MINUTES=10
DAILYNEWS_REQUIRE_TODAY=true
DAILYNEWS_API_URL=https://60s.viki.moe/v2/60s
# image: redirect to the original image URL; image-proxy: return proxied image bytes.
DAILYNEWS_IMAGE_ENCODING=image
# blacklist: send to all groups except DAILYNEWS_GROUP_IDS.
# whitelist: only send to DAILYNEWS_GROUP_IDS.
DAILYNEWS_GROUP_MODE=blacklist
DAILYNEWS_GROUP_IDS=[]

# Optional. Sunset glow query and private alert settings.
SUNSET_API_URL=https://sunsetbot.top/
SUNSET_DEFAULT_CITY=北京
SUNSET_MODEL=GFS
SUNSET_TIMEOUT_SECONDS=10.0
SUNSET_NOTIFY_ENABLED=true
SUNSET_NOTIFY_TIMES=["09:00","21:00"]
SUNSET_NOTIFY_THRESHOLD=中烧
SUNSET_OWNER_IDS=[]
