BOT_PORT=8080
LOG_LEVEL=INFO

# Optional. Keep this identical to the access token configured in NapCat/Lagrange.
ONEBOT_ACCESS_TOKEN=

# Optional. OpenAI-compatible chat endpoint used when the bot is @mentioned and no command handles the message.
AICHAT_KEY=
AICHAT_BASEURL=
AICHAT_MODEL=
AICHAT_DEFAULT_ROLE=default
AICHAT_HISTORY_LIMIT=12
AICHAT_ROLES_PATH=data/ai_chat_roles.json
AICHAT_SESSION_TTL_MINUTES=1440

# Optional. COC7 AI assistant settings. Empty values reuse AICHAT_*.
COC7_AI_KEY=
COC7_AI_BASEURL=
COC7_AI_MODEL=

# Optional. Daily 60s news scheduler and group filter.
DAILYNEWS_ENABLED=true
DAILYNEWS_TIME=08:30
# If the source still returns yesterday's date at DAILYNEWS_TIME, retry until this time.
DAILYNEWS_LATEST_TIME=10:10
DAILYNEWS_RETRY_INTERVAL_MINUTES=10
DAILYNEWS_REQUIRE_TODAY=true
DAILYNEWS_API_URL=https://60s.viki.moe/v2/60s
# image: redirect to the original image URL; image-proxy: return proxied image bytes.
DAILYNEWS_IMAGE_ENCODING=image
# blacklist: send to all groups except DAILYNEWS_GROUP_IDS.
# whitelist: only send to DAILYNEWS_GROUP_IDS.
DAILYNEWS_GROUP_MODE=blacklist
DAILYNEWS_GROUP_IDS=[]
