BOT_PORT=8080
LOG_LEVEL=INFO

# Optional. Keep this identical to the access token configured in NapCat/Lagrange.
ONEBOT_ACCESS_TOKEN=

# Optional. OpenAI-compatible chat endpoint used when the bot is @mentioned and no command handles the message.
AICHAT_KEY=
AICHAT_BASEURL=
AICHAT_MODEL=
AICHAT_DEFAULT_ROLE=default
AICHAT_HISTORY_LIMIT=12
AICHAT_ROLES_PATH=data/ai_chat_roles.json
